# Copy this to behavioral-dummy-env (no .example suffix) and fill in secrets.
# This file is NEVER committed to git.

# jemalloc — prevents memory fragmentation during PCM audio streaming.
# Path for Ubuntu 24.04 ARM (Graviton2). Verify with:
#   ldconfig -p | grep libjemalloc
LD_PRELOAD=/usr/lib/aarch64-linux-gnu/libjemalloc.so.2

# Database — single-user: point directly at RDS instance endpoint (no proxy needed).
# These pool values override config.py defaults (5/3) — 1 worker × (2+1) = 3 connections,
# well within db.t3.micro's ~110 max_connections limit.
# RDS rejects unencrypted connections (pg_hba is hostssl-only). asyncpg ignores
# `sslmode=require` (psycopg2 syntax) — must use `?ssl=require`.
DATABASE_URL=postgresql+asyncpg://bduser:CHANGE_ME@your-rds-instance.us-west-2.rds.amazonaws.com:5432/behavioral_dummy?ssl=require
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT=30

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_RESPONSE_MODEL=gpt-4o-mini

# ElevenLabs
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=pcm_16000

# Simli
SIMLI_API_KEY=...
SIMLI_FACE_ID=...
SIMLI_IS_TRINITY=true

# HeyGen — optional second avatar provider. Leave commented out to keep the
# UI single-provider (Simli only). When set, the frontend toggle exposes
# both Simli and HeyGen on the preview screen. Voice (incl. 3rd-party
# ElevenLabs) is bound to the interactive avatar in HeyGen's dashboard,
# so there is no HEYGEN_VOICE_ID env var.
#HEYGEN_API_KEY=...
#HEYGEN_AVATAR_ID=...
#HEYGEN_QUALITY=low

# App
CANDIDATE_NAME=Angel
LOG_LEVEL=INFO
ENVIRONMENT=production

# Access gate — single shared passcode + signed-cookie session.
# ACCESS_PASSCODE: choose ≥12 chars. This is the only thing protecting your
#   API credits — anyone with this string can run sessions on your account.
# SESSION_SECRET: random key used to sign auth cookies. Generate with:
#     python3 -c "import secrets; print(secrets.token_hex(32))"
#   Rotating this invalidates all existing sessions.
ACCESS_PASSCODE=CHANGE_ME_strong_passphrase
SESSION_SECRET=CHANGE_ME_64_hex_chars
