# ── Database ──────────────────────────────────────────────────────────────────
# Single-user deployment: point directly at the RDS instance endpoint.
#   DB_POOL_SIZE=2 and DB_MAX_OVERFLOW=1 keep max connections at 6 per worker,
#   well within db.t3.micro's ~110 max_connections limit. No RDS Proxy needed.
#
# Multi-user deployment: point at the RDS Proxy endpoint instead and raise
#   DB_POOL_SIZE/DB_MAX_OVERFLOW to handle concurrent sessions without
#   exhausting RDS max_connections under load.
DATABASE_URL=postgresql+asyncpg://bduser:CHANGE_ME@rds-instance-endpoint.us-west-2.rds.amazonaws.com:5432/behavioral_dummy
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_RESPONSE_MODEL=gpt-4o-mini
RAG_TOP_K=4

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=pcm_16000

# ── Simli ─────────────────────────────────────────────────────────────────────
SIMLI_API_KEY=...
SIMLI_FACE_ID=...
SIMLI_IS_TRINITY=true

# ── Circuit Breakers ──────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30.0

# ── App ───────────────────────────────────────────────────────────────────────
CANDIDATE_NAME=Angel
PCM_CHUNK_BYTES=6000
LOG_LEVEL=INFO
ENVIRONMENT=production
